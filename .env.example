# Copy to .env and fill in. .env is gitignored; .env.example is the tracked template.

# Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Managed agent + environment IDs (printed by: python setup_event_agent.py)
AGENT_ID=agent_...
ENVIRONMENT_ID=env_...

# Google Sheet id — the part between /d/ and /edit in the sheet URL
GOOGLE_SHEET_ID=your-spreadsheet-id

# Google service account — provide ONE of the following:
#   Local: path to your key file. Drop it in config/ as config/service-account.json
#   (gitignored). See config/service-account.example.json for the shape.
GOOGLE_SERVICE_ACCOUNT_FILE=config/service-account.json
#   CI: paste the full key JSON on one line instead (this is the GitHub Actions secret)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
